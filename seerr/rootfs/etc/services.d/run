#!/usr/bin/with-contenv bashio

TZ="$(bashio::config 'TZ')"
export TZ

CONFIG_PATH="/share/seerr/config"

echo "Using config at $CONFIG_PATH"

# criar estrutura se não existir (não falha se já existir)
mkdir -p "$CONFIG_PATH"
mkdir -p "$CONFIG_PATH/logs"

# apontar Seerr para /share
rm -rf /app/config
ln -s "$CONFIG_PATH" /app/config

echo "Starting Seerr..."

exec node dist/index.js

#!/usr/bin/with-contenv bashio

ADDON_SLUG="$(bashio::addon.slug)"
CONFIG_PATH="/addon_configs/${ADDON_SLUG}"

echo "Using config path: $CONFIG_PATH"

mkdir -p "$CONFIG_PATH"
mkdir -p "$CONFIG_PATH/logs"

# copiar config inicial se não existir
if [ ! -f "$CONFIG_PATH/settings.json" ]; then
    cp -r /app/config/* "$CONFIG_PATH/" 2>/dev/null || true
fi
